---
import { formatPrice } from '../lib/menu.schema';
import type { MenuCategory } from '../lib/menu.schema';

interface Props {
  category: MenuCategory;
  slug: string;
}

const { category, slug } = Astro.props;
---

<section id={slug} class="scroll-mt-24">
  <h3 class="font-display text-2xl font-semibold text-brand-700">{category.title}</h3>
  {category.note && <p class="mt-1 text-sm text-ink-800/70">{category.note}</p>}

  <ul class="mt-4 divide-y divide-brand-100">
    {
      category.items.map((item) => (
        <li class="flex flex-col gap-1 py-3 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
          <div class="sm:max-w-md">
            <p class="font-medium text-ink-900">
              {item.name}
              {item.tags?.map((tag) => (
                <span class="ml-2 rounded-full bg-brand-100 px-2 py-0.5 text-xs font-normal text-brand-700">
                  {tag}
                </span>
              ))}
            </p>
            {item.description && <p class="text-sm text-ink-800/70">{item.description}</p>}
          </div>
          {item.prices && item.prices.length > 0 && (
            <div class="flex shrink-0 flex-wrap gap-x-4 gap-y-1 text-sm font-semibold text-brand-700 sm:justify-end">
              {item.prices.map((price) => (
                <span>
                  {price.label && <span class="mr-1 font-normal text-ink-800/60">{price.label}</span>}
                  {formatPrice(price.amount)}
                </span>
              ))}
            </div>
          )}
        </li>
      ))
    }
  </ul>

  {
    category.extras && category.extras.length > 0 && (
      <p class="mt-3 text-xs text-ink-800/60">
        {category.extras.map((extra) => `${extra.label} : ${formatPrice(extra.amount)}`).join(' · ')}
      </p>
    )
  }
</section>
